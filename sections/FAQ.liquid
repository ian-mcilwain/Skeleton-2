<section class="FAQ">
  <div class="container">
      {% comment %} <h2>{{ section.settings.faq-section-heading }}</h2> {% endcomment %}
       <h2>FAQs</h2>
      {% for block in section.blocks %}
        <div class="questionAnswer closed">
          <div class="question"><p>{{ block.settings.question }}</p><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.3.1 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M297.4 438.6C309.9 451.1 330.2 451.1 342.7 438.6L502.7 278.6C515.2 266.1 515.2 245.8 502.7 233.3C490.2 220.8 469.9 220.8 457.4 233.3L320 370.7L182.6 233.4C170.1 220.9 149.8 220.9 137.3 233.4C124.8 245.9 124.8 266.2 137.3 278.7L297.3 438.7z"/></svg></div>
          <div class="answer"> {{ block.settings.answer }}</div>
        </div>
          
      {% endfor %}

  </div>
</section>


{% style %}
section.FAQ {
    padding: 60px 0;
    display: flex;
    justify-content: center;
}
section.FAQ .container {
    max-width: 800px;
    width: 50%;
}
section.FAQ .container h2 {
  margin-bottom: 20px;
  font-weight: 500;
}

section.FAQ .container .questionAnswer:first-of-type {
  border-top: 1px solid lightgrey;
}
section.FAQ .container .questionAnswer {
  overflow: hidden;
  transition: height 0.5s ease-in-out;
  /* border-top: 1px solid lightgrey; */
  border-bottom: 1px solid lightgrey;
}
section.FAQ .container .questionAnswer .question {
    display: flex;
    justify-content: space-between;
    padding-top: 20px;
    padding-bottom: 20px
}

section.FAQ .container .questionAnswer .question:hover {
  cursor: pointer;
  
}
section.FAQ .container .questionAnswer .question:hover p {
  font-weight: 500;
}

section.FAQ .container .questionAnswer.open .question p {
  font-weight: 500;
}
section.FAQ .container .questionAnswer .question svg {
    width: 20px;
    height: 20px;
    transition: all 0.5s;
}

section.FAQ .container .questionAnswer.open .question svg {
  transform: rotate(180deg);
}
section.FAQ .container .questionAnswer .question p {
    font-size: 24px;
    font-weight: 300;
    transition: all 0.2s;
}
section.FAQ .container .questionAnswer .answer {
  padding-bottom: 20px;
  transition: all 0.3s;
}

section.FAQ .container .questionAnswer.closed .answer {
  opacity: 0;
}

section.FAQ .container .questionAnswer.open .answer {
  opacity: 1;
}

section.FAQ .container .questionAnswer .answer p {
  font-size: 18px;
  line-height: 1.3;
  margin-bottom: 10px;
}

{% endstyle %}

{% javascript %}

  function setQuestionHeight() {
      document.querySelectorAll('.questionAnswer').forEach((element) => {
      console.log(element)
      const questionHeight = element.querySelector('.question').offsetHeight;
      console.log(questionHeight)
      element.style.height = `${questionHeight}px`;

    });
  }

  document.addEventListener("DOMContentLoaded", () => { setQuestionHeight()});

  document.querySelectorAll('.questionAnswer .question').forEach((element) => {
    element.addEventListener('click', () => {
    console.log(element);
    let questionAnswer = element.parentElement
    let answerHeight = questionAnswer.querySelector('.answer').offsetHeight;
    let questionHeight = element.offsetHeight;

    if (questionAnswer.classList.contains('closed')) {
      questionAnswer.style.height = `${questionHeight + answerHeight}px`
    } else if (questionAnswer.classList.contains('open')) {
      questionAnswer.style.height = `${questionHeight}px`
    }
    console.log(questionHeight);
    console.log(answerHeight)
    questionAnswer.classList.toggle("open")
    questionAnswer.classList.toggle("closed")
  });
    
  });

  let debounce = (callback, delay) => {
  let myTimeout;
  return () => {
    clearTimeout(myTimeout);
    myTimeout = setTimeout(() => {
      callback()
    }, delay);
  };
};

let doDebounce = debounce(() => setQuestionHeight(), 50)

window.addEventListener('resize', () => doDebounce());
{% endjavascript %}


{% schema %}
{
  "name": "FAQ section",
  "settings": [    {
      "type": "text",
      "id": "faq-section-heading",
      "label": "FAQ Section Heading"
    }],
  "presets": [
    {
      "name": "FAQ section",
      "category": "Text"
    }
  ],
  "blocks": [
     {
       "name": "Row",
       "type": "text",
       "settings": [
         {
           "type": "text",
           "id": "question",
           "label": "Question"
         },          {
           "type": "richtext",
           "id": "answer",
           "label": "Answer"
         }
       ]
     }
   ]
}
{% endschema %}
